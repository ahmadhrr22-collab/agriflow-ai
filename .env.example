# ================================
# AGRIFLOW AI — Environment Variables
# ================================

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agriflow_dev"

# Redis (Upstash / local)
REDIS_URL="redis://localhost:6379"

# NestJS
PORT=3001
JWT_SECRET="change-this-to-random-secret-in-production"
JWT_EXPIRES_IN="7d"

# FastAPI AI Service
AI_SERVICE_URL="http://localhost:8000"
AI_SERVICE_KEY="internal-secret-key"

# Gemini
GEMINI_API_KEY=""

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_NAME="AgriFlow AI"

# Environment
NODE_ENV="development"